# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://dummy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummy-key
OPENAI_API_KEY=dummy-openai-key

# Supabase direct connection string (for Drizzle migrations, NOT the pooler)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Twilio WhatsApp (Week 1) ─────────────────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
# The Sandbox number (format: +14155238886) or your production number
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── Meta WhatsApp Cloud API (Week 2 - leave empty for now) ──────────────────
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=

# ─── Inngest ─────────────────────────────────────────────────────────────────
# Get from: https://app.inngest.com → Settings
# Leave empty for local dev (Inngest Dev Server handles it automatically)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Langfuse (Day 11) ───────────────────────────────────────────────────────
# Get from: https://cloud.langfuse.com → Settings
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── App ─────────────────────────────────────────────────────────────────────
# Your public URL (used for Twilio webhook signature validation)
# Local dev: use your ngrok URL, e.g. https://abc123.ngrok-free.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
