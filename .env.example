# Supabase
# Get these from: https://supabase.com/dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://dummy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummy-key
# Server-only. Only needed for privileged server-side Supabase access.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase direct connection string (for Drizzle migrations, NOT the pooler)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# DeepSeek (web intelligence layer)
# Server-only. Never use NEXT_PUBLIC_ for API keys.
DEEPSEEK_API_KEY=
# Optional model override
DEEPSEEK_MODEL=deepseek-chat
# Optional override (default: https://api.deepseek.com)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI
OPENAI_API_KEY=sk-...
# Optional provider selection for server-side AI routes
AI_PROVIDER=openai
# Optional model override
OPENAI_MODEL=gpt-4o-mini

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# Meta WhatsApp Cloud API
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=

# Inngest
# Leave empty for local dev if Inngest Dev Server is handling events.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Resend
# Form bildirimleri için kullanılır. Boş bırakılırsa e-posta gönderimi atlanır.
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=team@tugobo.ai

# WhatsApp direct link shown in success states
NEXT_PUBLIC_WHATSAPP_CONTACT=https://wa.me/905000000000

# Sprint 23: Live operations (pilot hotel)
# UUID of the pilot hotel row in `hotels` table (server + client realtime)
PILOT_HOTEL_ID=
NEXT_PUBLIC_PILOT_HOTEL_ID=

# Public application URL used for Twilio webhook signature validation
# Production: https://app.tugobo.com
# Development: https://abc123.ngrok-free.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
